{
    "id": "org.kde.kommit",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kommit",
    "rename-icon": "kommit",
    "finish-args": [
        "--device=dri",
        "--filesystem=home",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=gpg-agent",
        "--socket=ssh-auth",
        "--socket=wayland",
        "--system-talk-name=org.freedesktop.UDisks2"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "/share/qlogging-categories6",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "libssh2",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.libssh2.org/download/libssh2-1.11.1.tar.gz",
                    "sha256": "d9ec76cbe34db98eec3539fe2c899d26b0c837cb3eb466a56b0f109cabf658f7",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1730,
                        "url-template": "https://www.libssh2.org/download/libssh2-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "libgit2",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS:BOOL=ON",
                "-DBUILD_TESTS:BOOL=OFF",
                "-DUSE_THREADS:BOOL=ON",
                "-DUSE_SSH:BOOL=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/libgit2/libgit2/archive/v1.9.3/libgit2-1.9.3.tar.gz",
                    "sha256": "d532172d7ab24d2a25944e2434212d63ee85f3650e97b5f7579e7f201a78ad64",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1627,
                        "url-template": "https://github.com/libgit2/libgit2/archive/v$version/libgit2-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "kommit",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/kommit/kommit-v1.7.1.tar.xz",
                    "sha256": "ddde514faed998f780b169be110c2bf116e9c817ceb5ecc73487c6947405f991",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 371772,
                        "url-template": "https://download.kde.org/stable/kommit/kommit-v$version.tar.xz"
                    }
                },
                {
                    "type": "patch",
                    "path": "fix-build-newer-libgit.patch"
                }
            ]
        }
    ]
}
